# Game Server Configuration
# Copy this file to .env and fill in real values

# Database
DB_NAME=mmo_prototype
DB_USER=postgres
DB_PASSWORD=CHANGE_ME
DB_HOST=127.0.0.1
DB_PORT=5432

# Game Server
SERVER_HOST=0.0.0.0
SERVER_PORT=27016
SERVER_MAX_CLIENTS=3000

# Chunk Server IP sent to clients (public IP or domain of the host running chunk-server)
# If unset, the IP from chunk-server's handshake is used as-is
CHUNK_SERVER_HOST=127.0.0.1

# Logging
LOG_LEVEL=info
LOG_LEVEL_NETWORK=warn
LOG_LEVEL_GAMELOOP=warn
LOG_LEVEL_EVENTS=warn
